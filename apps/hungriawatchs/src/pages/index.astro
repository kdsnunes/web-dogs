---
import BaseLayout from '../layouts/BaseLayout.astro';

const featured = [
  { name: 'Rolex Submariner', desc: 'Full Steel 41mm Automático', price: 'R$ 89.900' },
  { name: 'Audemars Piguet Royal Oak', desc: 'Blue Dial 41mm Automático', price: 'R$ 249.900' },
  { name: 'Omega Speedmaster', desc: 'Moonwatch Professional 42mm', price: 'R$ 45.900' },
  { name: 'IWC Portugieser', desc: 'Chronograph 41mm Automático', price: 'R$ 52.900' },
  { name: 'Patek Philippe Nautilus', desc: 'Blue Dial 40mm Automático', price: 'R$ 599.900' },
  { name: 'Breitling Navitimer', desc: 'B01 Chronograph 43mm', price: 'R$ 38.900' },
];

const categories = [
  'Rolex', 'Audemars Piguet', 'Patek Philippe', 'Omega', 'IWC', 'Breitling',
];
---

<BaseLayout title="Hungria Watchs — Alta Relojoaria">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <h1>Alta Relojoaria<br><span>com procedência</span></h1>
      <p class="hero-sub">Relógios seminovos de luxo com garantia, revisados e autenticados.</p>
      <a href="/relogios" class="btn-gold">Ver Coleção</a>
    </div>
  </section>

  <!-- Categorias -->
  <section class="categories">
    <div class="container">
      <h2>Marcas</h2>
      <div class="cat-grid">
        {categories.map((cat) => (
          <a href="/relogios" class="cat-item">
            <span class="cat-name">{cat}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Destaques -->
  <section class="featured">
    <div class="container">
      <h2>Destaques</h2>
      <div class="product-grid">
        {featured.map((item) => (
          <article class="product-card">
            <div class="product-img">
              <div class="placeholder-img"></div>
            </div>
            <div class="product-info">
              <h3>{item.name}</h3>
              <p class="product-desc">{item.desc}</p>
              <span class="product-price">{item.price}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="container">
      <h2>Atendimento personalizado</h2>
      <p>Fale com nossos especialistas pelo WhatsApp para encontrar o relógio ideal.</p>
      <a href="#" class="btn-gold">Fale Conosco</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 80%, rgba(201,169,110,0.08) 0%, transparent 60%);
  }
  .hero-inner {
    text-align: center;
    position: relative;
    z-index: 1;
    padding: 4rem 2rem;
  }
  .hero h1 {
    font-size: 3.5rem;
    line-height: 1.15;
    margin-bottom: 1.5rem;
    letter-spacing: -0.5px;
  }
  .hero h1 span { color: var(--accent); }
  .hero-sub {
    color: var(--text-secondary);
    font-size: 1.1rem;
    max-width: 480px;
    margin: 0 auto 2.5rem;
  }

  /* Botão dourado */
  .btn-gold {
    display: inline-block;
    padding: 14px 36px;
    border: 1.5px solid var(--accent);
    color: var(--accent);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }
  .btn-gold:hover {
    background: var(--accent);
    color: var(--bg-primary);
  }

  /* Categorias */
  .categories {
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .categories h2 {
    text-align: center;
    margin-bottom: 2.5rem;
    font-size: 2rem;
    color: var(--text-primary);
  }
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  @media (min-width: 600px) { .cat-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 900px) { .cat-grid { grid-template-columns: repeat(6, 1fr); } }
  .cat-item {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px 12px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    transition: all 0.2s ease;
    text-align: center;
  }
  .cat-item:hover {
    border-color: var(--accent);
    background: rgba(201,169,110,0.05);
  }
  .cat-name {
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--text-secondary);
  }
  .cat-item:hover .cat-name { color: var(--accent); }

  /* Destaques */
  .featured {
    padding: 5rem 0;
  }
  .featured h2 {
    text-align: center;
    margin-bottom: 3rem;
    font-size: 2rem;
  }
  .product-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 24px;
  }
  @media (min-width: 600px) { .product-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px) { .product-grid { grid-template-columns: repeat(3, 1fr); } }

  .product-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    overflow: hidden;
    transition: border-color 0.2s ease;
  }
  .product-card:hover { border-color: var(--accent); }

  .product-img { position: relative; }
  .placeholder-img {
    width: 100%;
    aspect-ratio: 1;
    background: linear-gradient(135deg, var(--bg-secondary) 0%, #222 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-info { padding: 20px; }
  .product-info h3 {
    font-family: "Playfair Display", serif;
    font-size: 1.1rem;
    font-weight: 500;
    margin-bottom: 4px;
  }
  .product-desc {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-bottom: 12px;
  }
  .product-price {
    color: var(--accent);
    font-size: 1.05rem;
    font-weight: 600;
  }

  /* CTA */
  .cta {
    padding: 5rem 0;
    text-align: center;
    border-top: 1px solid var(--border);
  }
  .cta h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }
  .cta p {
    color: var(--text-secondary);
    margin-bottom: 2rem;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }
</style>
