---
import BaseLayout from '../layouts/BaseLayout.astro';
import catalog from '../data/catalog.json';

const brands = [
  { name: 'Rolex', logo: '/brands/rolex.png' },
  { name: 'Omega', logo: '/brands/omega.png' },
  { name: 'Tudor', logo: '/brands/tudor-watches.png' },
  { name: 'Seiko', logo: '/brands/seiko.png' },
  { name: 'Franck Muller', logo: '/brands/franck-muller-geneve.png' },
  { name: 'Tissot', logo: '/brands/tissot.png' },
  { name: 'IWC', logo: '/brands/iwc-schaffhausen.png' },
];

const featured = catalog
  .flatMap(b => b.models)
  .filter(m => m.featured)
  .slice(0, 6);
---

<BaseLayout title="Hungria Watchs — Alta Relojoaria">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <h1>Alta Relojoaria<br><span>com procedência</span></h1>
      <p class="hero-sub">Relógios de luxo com garantia, revisados e autenticados.</p>
      <a href="/catalogo" class="btn-gold">Ver Coleção</a>
    </div>
  </section>

  <!-- Marcas -->
  <section class="categories">
    <div class="container">
      <h2>Marcas</h2>
      <div class="cat-grid">
        {brands.map((b) => (
          <a href="/catalogo" class="cat-item">
            <img src={b.logo} alt={b.name} class="brand-logo" />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Destaques -->
  <section class="featured">
    <div class="container">
      <h2>Destaques</h2>
      <div class="product-grid">
        {featured.map((item) => (
          <article class="product-card">
            <div class="product-img">
              <img src={item.images[0]} alt={item.name} loading="lazy" />
            </div>
            <div class="product-info">
              <h3>{item.name}</h3>
              {item.price && <span class="product-price">{item.price}</span>}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Comunidade -->
  <section class="community">
    <div class="container">
      <div class="community-inner">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="var(--accent)" class="community-icon"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        <h2>Faça parte da nossa comunidade</h2>
        <p>Entre no nosso grupo exclusivo no WhatsApp para novidades, lançamentos e ofertas especiais.</p>
        <a href="/comunidade" class="btn-community">Entrar na Comunidade</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="container">
      <h2>Atendimento personalizado</h2>
      <p>Fale com nossos especialistas pelo WhatsApp para encontrar o relógio ideal.</p>
      <a href="https://wa.me/5547992902838?text=Ol%C3%A1%2C%20gostaria%20de%20saber%20mais%20sobre%20os%20rel%C3%B3gios!" class="btn-gold" target="_blank" rel="noopener">Fale Conosco</a>
    </div>
  </section>

</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 80%, rgba(201,169,110,0.08) 0%, transparent 60%);
  }
  .hero-inner {
    text-align: center;
    position: relative;
    z-index: 1;
    padding: 4rem 2rem;
  }
  .hero h1 {
    font-size: 3.5rem;
    line-height: 1.15;
    margin-bottom: 1.5rem;
    letter-spacing: -0.5px;
  }
  .hero h1 span { color: var(--accent); }
  .hero-sub {
    color: var(--text-secondary);
    font-size: 1.1rem;
    max-width: 480px;
    margin: 0 auto 2.5rem;
  }

  .btn-gold {
    display: inline-block;
    padding: 14px 36px;
    border: 1.5px solid var(--accent);
    color: var(--accent);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }
  .btn-gold:hover {
    background: var(--accent);
    color: var(--bg-primary);
  }

  /* Marcas */
  .categories {
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .categories h2 {
    text-align: center;
    margin-bottom: 2.5rem;
    font-size: 2rem;
  }
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  @media (min-width: 600px) { .cat-grid { grid-template-columns: repeat(4, 1fr); } }
  @media (min-width: 900px) { .cat-grid { grid-template-columns: repeat(7, 1fr); } }
  .cat-item {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px 16px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    transition: all 0.2s ease;
  }
  .cat-item:hover {
    border-color: var(--accent);
    background: rgba(201,169,110,0.05);
  }
  .brand-logo {
    height: 28px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }
  .cat-item:hover .brand-logo { opacity: 1; }

  /* Destaques */
  .featured { padding: 5rem 0; }
  .featured h2 {
    text-align: center;
    margin-bottom: 3rem;
    font-size: 2rem;
  }
  .product-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 600px) { .product-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px) { .product-grid { grid-template-columns: repeat(3, 1fr); } }

  .product-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    overflow: hidden;
    transition: border-color 0.2s ease;
  }
  .product-card:hover { border-color: var(--accent); }
  .product-img {
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--bg-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .product-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .product-card:hover .product-img img { transform: scale(1.03); }

  .product-info { padding: 20px; }
  .product-info h3 {
    font-family: "Playfair Display", serif;
    font-size: 1.1rem;
    font-weight: 500;
    margin-bottom: 4px;
  }
  .product-price {
    color: var(--accent);
    font-size: 1rem;
    font-weight: 600;
  }

  /* Comunidade */
  .community {
    padding: 5rem 0;
    border-top: 1px solid var(--border);
  }
  .community-inner {
    text-align: center;
    background: linear-gradient(135deg, rgba(201,169,110,0.06) 0%, rgba(201,169,110,0.02) 100%);
    border: 1px solid rgba(201,169,110,0.2);
    padding: 3.5rem 2rem;
    max-width: 640px;
    margin: 0 auto;
  }
  .community-icon { margin-bottom: 1.2rem; }
  .community h2 {
    font-size: 1.8rem;
    margin-bottom: 0.8rem;
  }
  .community p {
    color: var(--text-secondary);
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }
  .btn-community {
    display: inline-block;
    padding: 14px 36px;
    background: #25D366;
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    border-radius: 2px;
    transition: all 0.2s ease;
  }
  .btn-community:hover {
    background: #20bd5a;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(37, 211, 102, 0.3);
  }

  /* CTA */
  .cta {
    padding: 5rem 0;
    text-align: center;
    border-top: 1px solid var(--border);
  }
  .cta h2 { font-size: 2rem; margin-bottom: 1rem; }
  .cta p {
    color: var(--text-secondary);
    margin-bottom: 2rem;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }
</style>
