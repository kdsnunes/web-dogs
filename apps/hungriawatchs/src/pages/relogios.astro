---
import BaseLayout from '../layouts/BaseLayout.astro';

const watches = [
  { name: 'Rolex Submariner', desc: 'Full Steel 41mm Automático Completo', price: 'R$ 89.900', brand: 'Rolex' },
  { name: 'Rolex Datejust 41mm', desc: 'Silver Dial Full Steel Automático', price: 'R$ 64.900', brand: 'Rolex' },
  { name: 'Rolex GMT-Master II', desc: '"Batman" Oyster 40mm Automático', price: 'R$ 104.900', brand: 'Rolex' },
  { name: 'Audemars Piguet Royal Oak', desc: 'Blue Dial Steel 41mm Automático', price: 'R$ 249.900', brand: 'Audemars Piguet' },
  { name: 'Audemars Piguet Royal Oak Offshore', desc: 'Panda Cerâmica 44mm', price: 'R$ 189.900', brand: 'Audemars Piguet' },
  { name: 'Patek Philippe Nautilus', desc: 'Flyback Chronograph Blue 40.5mm', price: 'R$ 699.900', brand: 'Patek Philippe' },
  { name: 'Omega Speedmaster', desc: 'Moonwatch Professional 42mm Corda', price: 'R$ 45.900', brand: 'Omega' },
  { name: 'IWC Portugieser', desc: 'Chronograph 41mm Automático', price: 'R$ 52.900', brand: 'IWC' },
  { name: 'IWC Big Pilot', desc: 'Le Petit Prince 46mm 8 Days Corda', price: 'R$ 77.900', brand: 'IWC' },
  { name: 'Breitling Navitimer', desc: 'B01 Chronograph 43mm Automático', price: 'R$ 38.900', brand: 'Breitling' },
  { name: 'Panerai Luminor Due', desc: 'Ultra Thin 45mm Titanium Blue', price: 'R$ 41.900', brand: 'Panerai' },
  { name: 'Hublot Big Bang', desc: 'Steel Ceramic 44mm Automático', price: 'R$ 68.900', brand: 'Hublot' },
];
---

<BaseLayout title="Relógios — Hungria Watchs">

  <section class="page-header">
    <div class="container">
      <h1>Relógios</h1>
      <p class="subtitle">Peças seminovas autenticadas e revisadas. Parcelamos em até 12x sem juros.</p>
    </div>
  </section>

  <section class="catalog">
    <div class="container">
      <div class="product-grid">
        {watches.map((w) => (
          <article class="product-card">
            <div class="product-img">
              <div class="placeholder-img">
                <span class="brand-label">{w.brand}</span>
              </div>
            </div>
            <div class="product-info">
              <h3>{w.name}</h3>
              <p class="product-desc">{w.desc}</p>
              <span class="product-price">{w.price}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .page-header {
    padding: 5rem 0 3rem;
    border-bottom: 1px solid var(--border);
    text-align: center;
  }
  .page-header h1 { font-size: 2.5rem; margin-bottom: 0.8rem; }
  .subtitle { color: var(--text-secondary); font-size: 1rem; }

  .catalog { padding: 4rem 0; }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 24px;
  }
  @media (min-width: 600px) { .product-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px) { .product-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1100px) { .product-grid { grid-template-columns: repeat(4, 1fr); } }

  .product-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    overflow: hidden;
    transition: border-color 0.2s ease;
  }
  .product-card:hover { border-color: var(--accent); }

  .placeholder-img {
    width: 100%;
    aspect-ratio: 1;
    background: linear-gradient(135deg, var(--bg-secondary) 0%, #222 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .brand-label {
    color: var(--text-muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
  }

  .product-info { padding: 16px; }
  .product-info h3 {
    font-family: "Playfair Display", serif;
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 4px;
  }
  .product-desc {
    color: var(--text-muted);
    font-size: 0.82rem;
    margin-bottom: 10px;
  }
  .product-price {
    color: var(--accent);
    font-size: 1rem;
    font-weight: 600;
  }
</style>
