---
import BaseLayout from '../../layouts/BaseLayout.astro';

const artigos = [
  {
    titulo: 'Cão Pet ou Cão para Exposição? Entenda a diferença',
    resumo: 'Entenda por que ambos podem representar a mesma qualidade de criação e como funciona a seleção na raça Shiba Inu.',
    slug: '/artigos/pet-vs-show/',
    data: '2026-06-25',
  },
];
---

<BaseLayout
  title="Artigos sobre Shiba Inu — Ninpozan Kennel"
  description="Artigos educativos sobre criação responsável de Shiba Inu: seleção genética, padrão da raça, exposições de conformação e cuidados com a raça."
  breadcrumbs={[{ name: "Artigos", url: "/artigos/" }]}
>

  <section class="page-header">
    <div class="container">
      <a href="/" class="back-link">← Início</a>
      <div class="divider">
        <span class="divider-symbol">筆</span>
      </div>
      <h1>Artigos</h1>
      <p class="page-desc">Conteúdo educativo sobre criação responsável, padrão da raça e o universo do Shiba Inu.</p>
    </div>
  </section>

  <section class="artigos-section">
    <div class="container">
      <div class="artigos-list">
        {artigos.map((a) => (
          <a href={a.slug} class="artigo-card panel">
            <span class="artigo-data">{new Date(a.data).toLocaleDateString('pt-BR')}</span>
            <h2 class="artigo-titulo">{a.titulo}</h2>
            <p class="artigo-resumo">{a.resumo}</p>
            <span class="artigo-cta">Ler artigo →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index: 1;
  }

  .page-header {
    padding: 4rem 0 2rem;
    text-align: center;
    position: relative;
    z-index: 1;
  }
  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--sumi);
    margin-bottom: 1rem;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--verde-rolex); }
  .page-header h1 {
    font-family: "Shippori Mincho B1", serif;
    font-size: 2.5rem;
    color: var(--verde-deep);
    margin-bottom: 0.8rem;
  }
  .page-desc {
    color: var(--sumi);
    font-size: 0.95rem;
    max-width: 520px;
    margin: 0 auto;
  }

  .artigos-section {
    padding: 2rem 0 5rem;
    position: relative;
    z-index: 1;
  }
  .artigos-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .artigo-card {
    display: block;
    padding: 2rem;
    background: var(--papel-escuro);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .artigo-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 96, 57, 0.1);
  }
  .artigo-data {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--sumi-light);
  }
  .artigo-titulo {
    font-family: "Shippori Mincho B1", serif;
    font-size: 1.3rem;
    color: var(--verde-deep);
    margin: 0.5rem 0 0.8rem;
    line-height: 1.4;
  }
  .artigo-resumo {
    font-size: 0.9rem;
    color: var(--sumi);
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .artigo-cta {
    font-size: 0.8rem;
    color: var(--dourado);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
</style>
