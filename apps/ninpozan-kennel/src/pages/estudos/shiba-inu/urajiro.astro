---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const articleTitle = 'O que é Urajiro? A Marcação Obrigatória do Shiba Inu';
const articleDescription = 'O que é urajiro no Shiba Inu? Entenda o significado, localização, importância no padrão da raça e como essa marcação influencia a expressão típica preservada pela NIPPO e FCI.';
const articleDate = '2026-06-25';
const articleModified = '2026-06-25';
const articleUrl = 'https://ninpozankennel.com.br/estudos/shiba-inu/urajiro/';
const pilarName = 'Conhecendo o Shiba Inu';
const pilarUrl = '/estudos/shiba-inu/';
